{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WordScript",
  "version": "0.2.0-alpha",
  "identifier": "com.felixontv.wordscript",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "overlay",
        "title": "WordScript",
        "url": "index.html#/overlay",
        "width": 312,
        "height": 68,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": true,
        "focus": false,
        "shadow": false
      },
      {
        "label": "settings",
        "title": "WordScript – Settings",
        "url": "index.html#/settings",
        "width": 700,
        "height": 520,
        "minWidth": 700,
        "minHeight": 520,
        "resizable": true,
        "center": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "appimage", "deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/wordscript-sidecar"],
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libayatana-appindicator3-1", "libxdo3"]
      }
    }
  },
  "plugins": {
    "shell": {
      "open": false
    }
  }
}
